        <mxCell id="axis3" value="③ Volatility Impact&#xa;vs baseline delta %" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1695" y="835" width="145" height="45" as="geometry" />
        </mxCell>
        <mxCell id="axis4" value="④ Spread Impact&#xa;vs baseline delta %" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1385" y="890" width="145" height="35" as="geometry" />
