        <!-- Axes -->
        <mxCell id="axis1" value="① Profitability&#xa;opportunity_capture_rate&#xa;= pnl / (spread × vol / 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1385" y="835" width="145" height="45" as="geometry" />
        </mxCell>
        <mxCell id="axis2" value="② Risk-Adjusted&#xa;Sharpe + drawdown penalty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1540" y="835" width="145" height="45" as="geometry" />
