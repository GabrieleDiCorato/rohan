        <mxCell id="scoring-label" value="Deterministic 6-Axis Scoring Pipeline (scoring.py)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1380" y="805" width="400" height="18" as="geometry" />
