        <mxCell id="m-verdict" value="JudgeVerdict&#xa;  score: float (1–10)&#xa;  comparison: better|worse|similar&#xa;  recommendation: continue|stop_*&#xa;  reasoning: str&#xa;  profitability_score: float&#xa;  risk_score: float&#xa;  volatility_impact_score: float&#xa;  spread_impact_score: float&#xa;  liquidity_impact_score: float&#xa;  execution_score: float" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;fontSize=8;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="290" y="835" width="210" height="145" as="geometry" />
        </mxCell>
        <mxCell id="m-aggfb" value="AggregatedFeedback&#xa;  verdict: JudgeVerdict&#xa;  cross_scenario_patterns: list[str]&#xa;  unified_feedback: str&#xa;  scenario_weaknesses: list[tuple]&#xa;  scenario_recommendations: list[tuple]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;fontSize=8;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="290" y="993" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="m-itersumm" value="IterationSummary&#xa;  iteration_number · strategy_code&#xa;  scenario_metrics · judge_score&#xa;  rolled_back · per-axis scores&#xa;  scoring_profile" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
