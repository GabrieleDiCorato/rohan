        <mxCell id="axis5" value="⑤ Liquidity Impact&#xa;vs baseline delta %" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1540" y="890" width="145" height="35" as="geometry" />
        </mxCell>
        <mxCell id="axis6" value="⑥ Execution Quality&#xa;fill_rate · OTT · slippage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;align=left;spacingLeft=3;" vertex="1" parent="1">
          <mxGeometry x="1695" y="890" width="145" height="35" as="geometry" />
        </mxCell>

        <!-- Weight profiles -->
        <mxCell id="weights" value="Weight Profiles (classify_goal_weights)&#xa;──────────────────────────&#xa;default:          P=0.35  R=0.20  V=0.07  S=0.08  L=0.05  E=0.25&#xa;impact_focused:   P=0.15  R=0.10  V=0.20  S=0.20  L=0.15  E=0.20&#xa;risk_focused:     P=0.15  R=0.40  V=0.07  S=0.08  L=0.05  E=0.25&#xa;execution_focused: P=0.15  R=0.15  V=0.07  S=0.08  L=0.05  E=0.50" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1385" y="940" width="465" height="85" as="geometry" />
        </mxCell>

        <!-- Final score -->
        <mxCell id="final-score" value="compute_final_score()&#xa;raw = Σ(axis × weight)&#xa;→ round to 0.5 → clamp [1.0, 10.0]&#xa;&#xa;   → JudgeVerdict.score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1385" y="1040" width="230" height="65" as="geometry" />
